     return (uint32_t(p[0]) << 24) | (uint32_t(p[1]) << 16) | (uint32_t(p[2]) << 8) | uint32_t(p[3]);
 }
 
+uint64_t rdBE64(const uint8_t * p)
+{
+    return (uint64_t(rdBE32(p)) << 32) | uint64_t(rdBE32(p + 4));
+}
